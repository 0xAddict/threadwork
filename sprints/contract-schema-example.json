          "statement": "gate-log-tail.sh exits 0 on happy path",
          "test_command": "bash threadwork/scripts/gate-log-tail.sh threadwork/tests/gate-log/sample.log 3 >/dev/null; echo $?",
          "expected": "0"
        },
        {
          "id": "AC-3",
          "statement": "gate-log-tail.sh exits 1 on missing file",
          "test_command": "bash threadwork/scripts/gate-log-tail.sh /nonexistent.log 3 >/dev/null 2>&1; echo $?",

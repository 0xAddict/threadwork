{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "lib": ["esnext", "dom"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": ["./.typeroots"],
    "types": ["bun-types", "node"]
  },
  "include": [
    "types/bun-sqlite-widen.d.ts",
    "reflection/outcome-feedback.ts",
    "db.ts",
    "server.ts",
    "debrief.ts",
    "tests/reflection/outcome-feedback.test.ts",
    "tests/reflection/pf1-4-sequence-behavior.test.ts",
    "tests/guardrails/pf1-4-wiring.guard.test.ts"
  ]
}
